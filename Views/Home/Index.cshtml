                    </div>
                    <button
                        class="w-full py-4 mt-2 md:mt-4 bg-gradient-to-r from-secondary to-tertiary text-white rounded-2xl font-black text-lg md:text-xl hover:scale-[1.02] transition-transform shadow-xl shadow-secondary/20 flex items-center justify-center gap-2"
                        type="submit">
                        NHẬN TƯ VẤN <span class="material-symbols-outlined">arrow_forward</span>
                    </button>
                    <p class="text-center text-xs text-on-surface-variant mt-2">Thông tin của bạn được bảo mật tuyệt
                        đối.</p>
                </form>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
    <script>
        // CLIENT-SIDE VALIDATION
        document.querySelectorAll('form[action="/Home/Register"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                const parentName = form.querySelector('[name="ParentName"]').value.trim();
                const childInfo = form.querySelector('[name="ChildInfo"]').value.trim();
                const phone = form.querySelector('[name="PhoneNumber"]').value.trim();
                const email = form.querySelector('[name="Email"]').value.trim();

                if (!parentName) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng nhập Họ tên phụ huynh.', confirmButtonText: 'Đóng', confirmButtonColor: '#ff972e' });
                    return;
                }
                if (!childInfo) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Thiếu thông tin', text: 'Vui lòng nhập Họ tên & Tuổi của con.', confirmButtonText: 'Đóng', confirmButtonColor: '#ff972e' });
                    return;
                }
                if (!phone && !email) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Thiếu liên hệ', text: 'Vui lòng cung cấp ít nhất Số điện thoại hoặc Email để chúng tôi liên hệ.', confirmButtonText: 'Đóng', confirmButtonColor: '#ff972e' });
                    return;
                }
                if (phone && !/^[0-9]{10}$/.test(phone)) {
                    e.preventDefault();
                    Swal.fire({ icon: 'error', title: 'Số điện thoại không hợp lệ', text: 'Số điện thoại phải bao gồm đúng 10 chữ số.', confirmButtonText: 'Đóng', confirmButtonColor: '#dc2626' });
                    return;
                }
            });
        });
    </script>
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: '@Html.Raw(TempData["Success"])',
                confirmButtonText: 'Đóng',
                confirmButtonColor: '#16a34a'
            });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Có lỗi xảy ra!',
                text: '@Html.Raw(TempData["Error"])',
                confirmButtonText: 'Đóng',
                confirmButtonColor: '#dc2626'
            });
        </script>
    }
</body>

</html>
