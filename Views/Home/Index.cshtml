@{ Layout = null; }
<!DOCTYPE html>

<html class="scroll-smooth" lang="vi">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>FUCAMP LÊ LỢI - Con Bạn Phi Thường Hơn Bạn Nghĩ</title>
    <!-- Favicon -->
    <link rel="icon" href="img/logo.png" type="image/png" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-tertiary-container": "#4d2700",
                        "primary-container": "#9df197",
                        "on-surface-variant": "#575d57",
                        "surface-container-low": "#ecf3ea",
                        "primary-fixed-dim": "#90e28a",
                        "secondary-container": "#ffc791",
                        "outline": "#727872",
                        "secondary-dim": "#764400",
                        "secondary-fixed-dim": "#ffb467",
                        "surface-container": "#e3eae1",
                        "inverse-surface": "#0a0f0b",
                        "surface-tint": "#176a21",
                        "surface-bright": "#f2f8f0",
                        "inverse-primary": "#9df197",
                        "error-dim": "#b92902",
                        "on-primary": "#d1ffc8",
                        "tertiary-dim": "#7a4100",
                        "error": "#b02500",
                        "tertiary": "#8b4b00",
                        "secondary-fixed": "#ffc791",
                        "secondary": "#874e00",
                        "primary-dim": "#025d16",
                        "background": "#f2f8f0",
                        "on-primary-fixed": "#00460e",
                        "on-tertiary-fixed": "#291200",
                        "error-container": "#f95630",
                        "on-secondary-fixed-variant": "#774400",
                        "inverse-on-surface": "#989f98",
                        "on-primary-fixed-variant": "#12661e",
                        "on-primary-container": "#005c15",
                        "surface": "#f2f8f0",
                        "on-surface": "#2a302b",
                        "tertiary-fixed-dim": "#f38800",
                        "on-error-container": "#520c00",
                        "on-secondary-container": "#6a3c00",
                        "surface-variant": "#d6dfd5",
                        "surface-dim": "#cdd7cd",
                        "tertiary-fixed": "#ff972e",
                        "on-background": "#2a302b",
                        "outline-variant": "#a9afa8",
                        "on-error": "#ffefec",
                        "on-tertiary-fixed-variant": "#592e00",
                        "on-secondary-fixed": "#4f2c00",
                        "surface-container-highest": "#d6dfd5",
                        "surface-container-high": "#dce5db",
                        "primary-fixed": "#9df197",
                        "primary": "#176a21",
                        "on-tertiary": "#fff0e6",
                        "on-secondary": "#fff0e5",
