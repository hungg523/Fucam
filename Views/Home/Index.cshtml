    <link href="style.css" rel="stylesheet" />
</head>

<body class="antialiased overflow-x-hidden">
    <!-- Top Navigation Shell -->
    <nav class="fixed top-0 w-full z-50 transition-all duration-500" id="navbar">
        <div
            class="glass mx-auto max-w-7xl mt-4 rounded-full border border-white/40 shadow-lg shadow-emerald-900/5 px-6 md:px-8 h-16 md:h-20 flex justify-between items-center transition-all duration-500">
            <div class="text-2xl font-black tracking-tight text-emerald-950 flex items-center gap-2 md:gap-3">
                <img src="img/logo.png" alt="Fucamp Logo" class="h-8 md:h-10 w-auto object-contain" />
                FUCAMP LÊ LỢI
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="text-emerald-950/80 font-bold hover:text-primary transition-all duration-300 hover:scale-105"
                    href="#journey">Lộ trình</a>
                <a class="text-emerald-950/80 font-bold hover:text-primary transition-all duration-300 hover:scale-105"
                    href="#values">Giá trị</a>
                <a class="text-emerald-950/80 font-bold hover:text-primary transition-all duration-300 hover:scale-105"
                    href="#pricing">Chi phí</a>
                <a class="relative group inline-flex items-center justify-center hover:-translate-y-0.5 transition-transform duration-300" href="#register">
                    <span
                        class="bg-orange-500 hover:bg-orange-600 text-white px-7 py-2.5 rounded-full font-black text-sm tracking-wide shadow-md shadow-orange-500/30 transition-all border border-orange-400">ĐĂNG KÝ THAM GIA</span>
                </a>
            </div>
            <button id="mobile-menu-btn" class="md:hidden text-emerald-900 p-2 z-[60] relative">
                <span id="mobile-menu-icon"
                    class="material-symbols-outlined text-3xl transition-transform duration-300">menu</span>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu"
        class="fixed top-[88px] left-4 right-4 z-40 bg-white/95 backdrop-blur-lg rounded-3xl shadow-2xl border border-white/50 transform origin-top scale-y-0 opacity-0 transition-all duration-300 md:hidden flex flex-col overflow-hidden pointer-events-none">
        <div class="px-6 py-6 flex flex-col gap-5 text-center">
            <a class="text-lg font-black text-emerald-950 active:text-primary mobile-menu-link" href="#journey">Lộ trình
                6 ngày</a>
            <div class="h-px bg-gradient-to-r from-transparent via-emerald-900/10 to-transparent w-full"></div>
            <a class="text-lg font-black text-emerald-950 active:text-primary mobile-menu-link" href="#values">Giá trị
                huấn luyện</a>
            <div class="h-px bg-gradient-to-r from-transparent via-emerald-900/10 to-transparent w-full"></div>
            <a class="text-lg font-black text-emerald-950 active:text-primary mobile-menu-link" href="#pricing">Chi phí
                đầu tư</a>
            <div class="mt-2 text-center w-full">
                <a class="inline-block w-full px-6 py-4 bg-gradient-to-r from-primary to-primary-dim text-white rounded-2xl font-black text-lg shadow-xl shadow-primary/20 mobile-menu-link"
                    href="#register">
                    GIỮ CHỖ NGAY
                </a>
            </div>
        </div>
    </div>
    <!-- Hero Section -->
    <section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <video class="w-full h-full object-cover scale-105 parallax-hero" style="object-position: center 70%;"
                autoplay loop muted playsinline poster="img/hero-banner.jpg">
                <source src="video/hero-banner.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-hero-overlay"></div>
        </div>

        <div class="relative z-10 text-center px-6 max-w-5xl mx-auto pt-16 pb-24">
            <span
                class="inline-block px-5 py-2 rounded-full glass-dark text-white border border-white/20 mb-6 font-bold tracking-widest text-sm uppercase">Khai
                Phá Tiềm Năng</span>
            <h1 class="text-5xl md:text-7xl lg:text-[85px] font-black text-white mb-4 drop-shadow-lg"
                style="line-height: 1.4 !important;">
                FUCAMP LÊ LỢI<br />
                <span class="text-primary-container">CON BẠN<br />PHI THƯỜNG</span><br />
                HƠN BẠN NGHĨ
            </h1>
            <p
                class="text-white/90 max-w-3xl mx-auto text-xl md:text-2xl font-medium mb-8 drop-shadow-md leading-relaxed hidden sm:block">
                Với tâm huyết đồng hành cùng thế hệ tương lai, <strong class="text-white font-bold">TRẠI HÈ FUCAMP LÊ
                    LỢI</strong> là chương trình trải nghiệm do Trường Lê Lợi tổ chức. Một trại huấn luyện thực tế nơi
                trẻ rèn luyện bản lĩnh, khai mở tư duy và phát triển nhân cách.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a class="w-full sm:w-auto px-10 py-4 bg-primary text-white rounded-full text-lg font-bold hover:bg-primary-dim transition-colors shadow-lg"
                    href="#difference">
                    Khám phá ngay
                </a>
                <a class="w-full sm:w-auto px-10 py-4 glass-dark text-white border border-white/30 rounded-full text-lg font-bold hover:bg-white/20 transition-colors"
                    href="#journey">
                    Lộ trình 6 ngày
                </a>
            </div>
        </div>
        <div class="absolute bottom-8 w-full flex justify-center opacity-70 pointer-events-none">
            <div class="animate-bounce">
                <span
                    class="material-symbols-outlined text-white text-4xl drop-shadow-lg">keyboard_double_arrow_down</span>
            </div>
        </div>
    </section>
    <!-- Difference Section -->
    <section class="py-16 md:py-24 bg-surface lg:min-h-screen lg:flex lg:items-center" id="difference">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="relative group">
                <div
                    class="absolute -inset-4 bg-primary/10 rounded-[40px] rotate-2 group-hover:rotate-0 transition-transform duration-500">
                </div>
                <img class="relative rounded-[32px] shadow-2xl z-10 w-full aspect-[4/5] object-cover"
                    data-alt="Young campers working together to build a wooden shelter in a nature park, focused expressions, earthy tones, cinematic lighting"
                    src="img/about-intro.jpg" />
                <div class="absolute -bottom-6 -right-6 bg-white p-8 rounded-2xl shadow-xl z-20 max-w-[240px]">
                    <p class="text-primary font-black text-4xl mb-1">100%</p>
                    <p class="text-on-surface-variant font-medium leading-tight">Trải nghiệm thực tế không sách vở</p>
                </div>
            </div>
            <div class="reveal">
                <label class="text-primary font-bold tracking-widest uppercase mb-4 block">Khác Biệt Đột Phá</label>
                <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-[52px] xl:text-6xl font-extrabold text-on-surface mb-8 leading-[1.4] tracking-normal">
                    <span class="whitespace-nowrap">Không chỉ là trại hè,</span> <br />
                    <span class="text-primary mt-2 inline-block">mô hình quốc tế</span> 
                    <span class="whitespace-nowrap inline-block mt-2">thực thụ.</span>
                </h2>
                <p class="text-xl text-on-surface-variant leading-relaxed mb-10">
                    FUCAMP LÊ LỢI là nơi những kỹ năng sống thực tế được rèn luyện thông qua các thử thách sinh tồn,
                    quản lý tài chính và tư duy lãnh đạo trong môi trường tự nhiên hùng vĩ.
                </p>
                <ul class="space-y-6">
                    <li class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-xl bg-primary-container flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-primary font-bold">verified</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-on-surface">Mô hình đào tạo chuẩn Global</h4>
                            <p class="text-on-surface-variant">Áp dụng phương pháp kiến tạo giúp con tự chủ trong mọi
                                quyết định.</p>
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-xl bg-secondary-container flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-secondary font-bold">groups</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg text-on-surface">Đội ngũ chuyên gia tâm lý</h4>
                            <p class="text-on-surface-variant">Sát cánh cùng con trong mọi cảm xúc, giúp con thấu hiểu
                                bản thân.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </section>
    <!-- Core Training Values Section -->
    <section class="py-16 md:py-24 bg-[#FFF9EB]" id="core-values">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16 reveal">
                <span
                    class="inline-block px-4 py-1.5 rounded-full bg-secondary-container/30 text-secondary-dim border border-secondary-container/50 mb-4 font-bold tracking-widest text-sm uppercase">Nền
                    tảng</span>
                <h2 class="text-4xl md:text-5xl font-black py-2 leading-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-rose-500 to-purple-600 drop-shadow-sm">CÁC GIÁ TRỊ CHÍNH HUẤN LUYỆN</h2>
                <div class="w-24 h-1.5 bg-gradient-to-r from-orange-500 to-purple-600 mx-auto rounded-full"></div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-fr gap-4 md:gap-6 reveal">
                <div
                    class="h-full bg-gradient-to-br from-emerald-400 to-teal-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-emerald-500/30 border-none hover:shadow-xl hover:shadow-emerald-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">mood</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Quản trị cảm xúc và phát
                        triển EQ</h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-amber-400 to-orange-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-amber-500/30 border-none hover:shadow-xl hover:shadow-amber-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">psychology</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Thấu hiểu bản thân</h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-orange-400 to-red-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-orange-500/30 border-none hover:shadow-xl hover:shadow-orange-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">model_training</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Thiết kế tương lai &amp; lập
                        mục tiêu</h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-blue-400 to-indigo-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-blue-500/30 border-none hover:shadow-xl hover:shadow-blue-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">security</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Kỹ năng bảo vệ bản thân</h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-teal-400 to-cyan-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-teal-500/30 border-none hover:shadow-xl hover:shadow-teal-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">directions_run</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Rèn luyện thể chất và sức bền
                    </h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-rose-400 to-pink-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-rose-500/30 border-none hover:shadow-xl hover:shadow-rose-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">bolt</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Tạo động lực, kiên trì hành
                        động</h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-purple-400 to-fuchsia-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-purple-500/30 border-none hover:shadow-xl hover:shadow-purple-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">trending_up</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Kế hoạch chinh phục học tập
                    </h3>
                </div>
                <div
                    class="h-full bg-gradient-to-br from-fuchsia-500 to-pink-500 p-5 md:p-6 rounded-3xl shadow-lg shadow-fuchsia-500/30 border-none hover:shadow-xl hover:shadow-fuchsia-500/40 transition-all hover:-translate-y-1 flex items-center gap-5 group">
                    <div
                        class="w-14 h-14 shrink-0 rounded-2xl bg-white/20 backdrop-blur-sm text-white flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">volunteer_activism</span>
                    </div>
                    <h3 class="font-black text-base md:text-lg text-white leading-snug drop-shadow-md">Xây dựng giá trị cốt lõi cá
                        nhân</h3>
                </div>
            </div>
        </div>
    </section>
    <!-- Values & Benefits Section -->
    <section class="py-16 md:py-24 bg-gradient-to-b from-[#F0FAFF] to-[#E0F2FE] overflow-hidden" id="values-benefits">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-12 md:mb-20 reveal">
                <h2 class="text-4xl md:text-6xl font-black py-2 leading-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-sky-500 to-indigo-600 drop-shadow-sm">Tại sao nên chọn FUCAMP LÊ LỢI?</h2>
                <div class="w-24 h-1.5 bg-gradient-to-r from-sky-500 to-indigo-600 mx-auto mb-10 rounded-full"></div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 mb-16">
                <!-- Card 1: Những ai nên tham gia -->
                <div
                    class="group relative overflow-hidden rounded-[32px] p-6 md:p-8 reveal shadow-lg min-h-[320px] flex items-end">
                    <div class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700 transform-gpu"
                        style="background-image: url('img/gallery-01.jpg');"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-emerald-950 via-emerald-950/80 to-transparent">
                    </div>
                    <div class="relative z-10 w-full mt-auto">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-12 h-12 rounded-xl bg-emerald-500 text-white flex items-center justify-center shrink-0 shadow-lg shadow-emerald-500/30">
                                <span class="material-symbols-outlined text-2xl">family_restroom</span>
                            </div>
                            <h3 class="text-xl md:text-2xl font-extrabold text-white">Mục tiêu công dân toàn cầu</h3>
                        </div>
                        <p class="text-emerald-50 text-base md:text-[17px] leading-relaxed font-medium">Cha mẹ muốn con phát triển toàn diện, khơi dậy bản lĩnh tự lập, có ý thức cộng đồng và hành động vì thế giới.</p>
                    </div>
                </div>
                <!-- Card 2: Con bạn phi thường hơn bạn nghĩ -->
                <div
                    class="group relative overflow-hidden rounded-[32px] p-6 md:p-8 reveal shadow-lg min-h-[320px] flex items-end">
                    <div class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700 transform-gpu"
                        style="background-image: url('img/gallery-02.jpg');"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-[#4f2e00] via-[#4f2e00]/80 to-transparent"></div>
                    <div class="relative z-10 w-full mt-auto">
                        <div class="flex items-center gap-4 mb-4">
                            <div
                                class="w-12 h-12 rounded-xl bg-amber-600 text-white flex items-center justify-center shrink-0 shadow-lg shadow-amber-600/30">
                                <span class="material-symbols-outlined text-2xl">psychology</span>
                            </div>
                            <h3 class="text-xl md:text-2xl font-extrabold text-white">Con bạn phi thường hơn bạn nghĩ
                            </h3>
                        </div>
                        <p class="text-orange-50 text-base md:text-[17px] leading-relaxed font-medium">Chúng tôi giúp
                            con phá bỏ những niềm tin giới hạn, tạo cơ hội để bứt phá và khơi dậy nội lực tuyệt vời ẩn
                            sâu bên trong mỗi đứa trẻ.</p>
                    </div>
                </div>
                <!-- Card 3: Gia đình là nền tảng gốc rễ -->
                <div
                    class="group relative overflow-hidden rounded-[32px] p-6 md:p-8 reveal shadow-lg min-h-[320px] flex items-end">
                    <div class="absolute inset-0 bg-cover bg-center group-hover:scale-110 transition-transform duration-700 transform-gpu"
                        style="background-image: url('img/gallery-03.jpg');"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-[#592600] via-[#592600]/80 to-transparent"></div>
                    <div class="relative z-10 w-full mt-auto">
                        <div class="flex items-center gap-4 mb-4">
