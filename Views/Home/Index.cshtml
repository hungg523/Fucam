                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Be Vietnam Pro", "sans-serif"],
                        "body": ["Be Vietnam Pro", "sans-serif"],
                        "label": ["Be Vietnam Pro", "sans-serif"]
                    }
                },
            },
