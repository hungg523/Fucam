@model IEnumerable<Fucam.Models.Registration>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị Fucamp Lê Lợi</title>
    <link rel="icon" href="/img/logo.png" type="image/png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        #sidebar { transition: transform 0.3s ease; }
        #sidebar-overlay { transition: opacity 0.3s ease; }
        .sidebar-open #sidebar { transform: translateX(0); }
        .sidebar-open #sidebar-overlay { opacity: 1; pointer-events: auto; }
    </style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden">

    <!-- Sidebar Overlay (Mobile) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 opacity-0 pointer-events-none lg:hidden" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="fixed lg:relative w-64 bg-slate-900 h-full flex flex-col text-white z-50 -translate-x-full lg:translate-x-0 shrink-0">
        <div class="p-6 pb-2 border-b border-slate-800 flex flex-col">
            <a href="/" target="_blank" title="Xem trang web tải tab mới" class="text-2xl font-black text-amber-500 tracking-wide flex items-center gap-3 hover:scale-[1.02] transition-transform">
                <img src="/img/logo.png" alt="Fucamp Lê Lợi" class="h-9 object-contain brightness-0 invert drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)]" />
                FUCAMP
            </a>
            <div class="text-[11px] text-slate-400 font-bold tracking-widest mt-2 uppercase ml-12">Quản trị hệ thống</div>
        </div>
        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/quan-tri" class="flex items-center gap-3 py-3 px-4 rounded-xl transition bg-blue-600 text-white font-medium shadow-md shadow-blue-900/20">
                <span class="material-symbols-outlined">dataset</span>
                Danh sách đăng ký
            </a>
        </nav>
        <div class="p-4 border-t border-slate-800">
             <a href="/quan-tri/logout" class="flex items-center gap-3 py-3 px-4 rounded-xl transition text-red-400 hover:bg-slate-800 hover:text-red-300 font-medium w-full">
                <span class="material-symbols-outlined">logout</span>
                Đăng xuất
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden w-full">
        <!-- Header -->
        <header class="bg-white border-b border-slate-200 px-4 md:px-8 py-3 md:py-4 flex justify-between items-center shrink-0">
            <div class="flex items-center gap-3">
                <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center text-slate-600 hover:bg-slate-200 transition">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <h1 class="text-lg md:text-2xl font-bold text-slate-800 tracking-tight">Danh sách đăng ký</h1>
            </div>
            <div class="flex items-center gap-3">
                <div class="text-right hidden md:block">
                    <div class="text-sm font-semibold text-slate-700">Admin</div>
                    <div class="text-xs text-slate-500">Quản trị viên</div>
                </div>
                <div class="w-10 h-10 rounded-full bg-slate-200 border-2 border-white shadow-sm flex items-center justify-center text-slate-500">
                    <span class="material-symbols-outlined">person</span>
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-auto p-4 md:p-8 bg-slate-50">
            <!-- Analytics Cards & Chart -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <!-- Data Cards -->
                <div class="grid grid-cols-2 gap-4">
                    <a href="/quan-tri" class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between hover:shadow-md transition-shadow group">
                        <div>
                            <p class="text-xs font-semibold text-slate-500 mb-1">Tổng đăng ký</p>
                            <h3 class="text-2xl font-black text-slate-800">@ViewBag.GlobalTotal</h3>
                        </div>
                        <div class="w-11 h-11 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">groups</span>
                        </div>
                    </a>
                    <a href="/quan-tri" class="bg-gradient-to-br from-amber-500 to-orange-500 p-5 rounded-2xl shadow-md border border-amber-400 flex items-center justify-between text-white hover:shadow-lg transition-shadow group">
                        <div>
                            <p class="text-xs font-semibold text-orange-100 mb-1">Hôm nay</p>
                            <h3 class="text-2xl font-black">@ViewBag.TodayTotal</h3>
                        </div>
                        <div class="w-11 h-11 rounded-full bg-white/20 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">today</span>
                        </div>
                    </a>
                    <a href="/quan-tri?statusFilter=1" class="bg-emerald-50 p-5 rounded-2xl shadow-sm border border-emerald-200 flex items-center justify-between hover:shadow-md transition-shadow group">
                        <div>
                            <p class="text-xs font-semibold text-emerald-600 mb-1">Đã liên hệ</p>
                            <h3 class="text-2xl font-black text-emerald-700">@ViewBag.ContactedTotal</h3>
                        </div>
                        <div class="w-11 h-11 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">check_circle</span>
                        </div>
                    </a>
                    <a href="/quan-tri?statusFilter=0" class="bg-rose-50 p-5 rounded-2xl shadow-sm border border-rose-200 flex items-center justify-between hover:shadow-md transition-shadow group">
                        <div>
                            <p class="text-xs font-semibold text-rose-600 mb-1">Chưa liên hệ</p>
                            <h3 class="text-2xl font-black text-rose-700">@ViewBag.NotContactedTotal</h3>
                        </div>
                        <div class="w-11 h-11 rounded-full bg-rose-100 text-rose-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="material-symbols-outlined text-2xl">pending_actions</span>
                        </div>
                    </a>
                </div>

                <!-- Chart Canvas -->
                <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                    <h3 class="text-base font-bold text-slate-800 mb-4">Lưu lượng đăng ký (7 ngày qua)</h3>
                    <div class="h-48 w-full relative">
                        <canvas id="registrationChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Filter Actions -->
            <form method="get" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4 mb-6">
                <div class="flex flex-col lg:flex-row items-end gap-3">
                    <!-- Search -->
                    <div class="flex-1 w-full">
                        <label class="text-xs font-semibold text-slate-500 mb-1 block">Tìm kiếm</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                            <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Tên, SĐT, Email, Tên bé..." class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm" />
                        </div>
                    </div>
                    <!-- Từ ngày -->
                    <div class="w-full lg:w-40">
                        <label class="text-xs font-semibold text-slate-500 mb-1 block">Từ ngày</label>
                        <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm" />
                    </div>
                    <!-- Đến ngày -->
                    <div class="w-full lg:w-40">
                        <label class="text-xs font-semibold text-slate-500 mb-1 block">Đến ngày</label>
                        <input type="date" name="dateTo" value="@ViewBag.DateTo" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm" />
                    </div>
                    <!-- Trạng thái -->
                    <div class="w-full lg:w-44">
                        <label class="text-xs font-semibold text-slate-500 mb-1 block">Trạng thái</label>
                        <select name="statusFilter" class="w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm bg-white">
                            @Html.Raw("<option value=\"\"" + (ViewBag.StatusFilter == null ? " selected" : "") + ">Tất cả</option>")
                            @Html.Raw("<option value=\"0\"" + (ViewBag.StatusFilter != null && (int)ViewBag.StatusFilter == 0 ? " selected" : "") + ">Chưa liên hệ</option>")
                            @Html.Raw("<option value=\"1\"" + (ViewBag.StatusFilter != null && (int)ViewBag.StatusFilter == 1 ? " selected" : "") + ">Đã liên hệ</option>")
                        </select>
                    </div>
                    <!-- Buttons -->
                    <div class="flex gap-2">
                        <button type="submit" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 transition-colors shadow-sm">
                            <span class="material-symbols-outlined text-sm">filter_alt</span> Lọc
                        </button>
                        <a href="/quan-tri" class="inline-flex items-center gap-1 px-4 py-2 rounded-lg bg-slate-100 text-slate-600 text-sm font-medium hover:bg-slate-200 transition-colors border border-slate-200">
                            <span class="material-symbols-outlined text-sm">restart_alt</span> Xóa lọc
                        </a>
                    </div>
                </div>
            </form>

            <div class="flex justify-end mb-4">
                <div class="text-sm text-slate-600 bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm font-medium">
                    Tổng cộng: <span class="text-blue-600 font-bold">@ViewBag.TotalRecords</span> bản ghi
                </div>
            </div>

            <!-- Table -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200 text-slate-600 text-sm">
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Thời gian</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Họ tên Phụ huynh</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Số điện thoại</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Email</th>
                                <th class="py-4 px-6 font-semibold min-w-[200px]">Họ tên & Tuổi của con</th>
                                <th class="py-4 px-6 font-semibold min-w-[150px]">Ghi chú</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap text-center">Trạng thái</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-slate-50/80 transition-colors">
                                        <td class="py-4 px-6 text-slate-500">
                                            <div class="font-medium text-slate-700">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                            <div class="text-xs">@item.CreatedAt.ToString("HH:mm")</div>
                                        </td>
                                        <td class="py-4 px-6 font-medium text-slate-800">
                                            @item.ParentName
                                        </td>
                                        <td class="py-4 px-6 font-medium text-blue-600">
                                            @item.PhoneNumber
                                        </td>
                                        <td class="py-4 px-6 text-slate-600">
                                            @if(!string.IsNullOrEmpty(item.Email))
                                            {
                                                <a href="mailto:@item.Email" class="hover:text-blue-600 hover:underline">@item.Email</a>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 italic">--</span>
                                            }
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="bg-orange-50 text-orange-800 px-3 py-1.5 rounded-lg border border-orange-100 inline-block">
                                                @item.ChildInfo
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 text-slate-600 text-sm max-w-[200px] break-words" id="note-col-@item.Id" data-note="@item.Notes">
                                            @if(!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <span class="italic">@item.Notes</span>
                                            }
                                            else
                                            {
                                                <span class="text-slate-300">--</span>
                                            }
                                        </td>
                                        <td class="py-4 px-6 text-center">
                                            @if(item.Status == 1) {
                                                <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200 cursor-default" title="Đã xác nhận liên hệ">
                                                    <span class="material-symbols-outlined text-sm">check_circle</span> <span>Đã liên hệ</span>
                                                </span>
                                            } else {
                                                <button onclick="toggleStatus(@item.Id, this)" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold transition-all shadow-sm focus:ring-2 focus:ring-offset-1 bg-rose-100 text-rose-700 border border-rose-200 hover:bg-rose-200 focus:ring-rose-400 cursor-pointer">
                                                    <span class="material-symbols-outlined text-sm">pending_actions</span> <span class="status-text">Chưa LH</span>
                                                </button>
                                            }
                                        </td>
                                        <td class="py-4 px-6 text-center">
                                            <div class="flex justify-center gap-2">
                                                <button onclick="editNote(@item.Id)" class="w-8 h-8 inline-flex items-center justify-center rounded-lg bg-slate-100 text-slate-500 hover:bg-blue-100 hover:text-blue-600 transition" title="Sửa ghi chú">
                                                    <span class="material-symbols-outlined text-[18px]">edit_note</span>
                                                </button>
                                                <button onclick="deleteContact(@item.Id, this)" class="w-8 h-8 inline-flex items-center justify-center rounded-lg bg-slate-100 text-slate-500 hover:bg-rose-100 hover:text-rose-600 transition" title="Xóa">
                                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="py-12 text-center text-slate-500 flex-col items-center">
                                        <span class="material-symbols-outlined text-4xl text-slate-300 mb-2 block">inbox</span>
                                        Không tìm thấy dữ liệu đăng ký nào.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="px-4 md:px-6 py-4 border-t border-slate-200 flex flex-col sm:flex-row justify-between items-center gap-3 bg-slate-50/50">
                        <div class="text-sm text-slate-500">
                            Trang <span class="font-medium text-slate-800">@ViewBag.CurrentPage</span> / @ViewBag.TotalPages
                        </div>
                        <div class="flex gap-1">
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <a href="/quan-tri?page=@(ViewBag.CurrentPage - 1)&searchString=@ViewBag.SearchString&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo&statusFilter=@ViewBag.StatusFilter" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition">
                                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                                </a>
                            }
                            
                            <!-- Hiển thị nhanh tối đa 5 trang -->
                            @{
                                int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                int endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                                if (endPage - startPage < 4) { startPage = Math.Max(1, endPage - 4); }
                            }
                            
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                if (i == ViewBag.CurrentPage)
                                {
                                    <span class="w-9 h-9 flex items-center justify-center rounded-lg bg-blue-600 text-white font-medium text-sm shadow-sm">@i</span>
                                }
                                else
                                {
                                    <a href="/quan-tri?page=@i&searchString=@ViewBag.SearchString&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo&statusFilter=@ViewBag.StatusFilter" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 font-medium text-sm transition">@i</a>
                                }
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <a href="/quan-tri?page=@(ViewBag.CurrentPage + 1)&searchString=@ViewBag.SearchString&dateFrom=@ViewBag.DateFrom&dateTo=@ViewBag.DateTo&statusFilter=@ViewBag.StatusFilter" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition">
                                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('registrationChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 200);
        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
        gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels)],
                datasets: [{
                    label: 'Số lượt đăng ký',
                    data: [@Html.Raw(ViewBag.ChartCounts)],
                    borderColor: '#2563eb',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#2563eb',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 },
                        grid: { borderDash: [2, 4], color: '#e2e8f0' }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
    <script>
        function toggleStatus(id, btnElement) {
            Swal.fire({
                title: 'Xác nhận đã liên hệ?',
                input: 'textarea',
                inputLabel: 'Ghi chú thêm (Không bắt buộc)',
                inputPlaceholder: 'Nhập nội dung trao đổi...',
                showCancelButton: true,
                confirmButtonText: 'Xác nhận đã liên hệ',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#10b981',
                heightAuto: false,
                scrollbarPadding: false
            }).then((result) => {
                if (result.isConfirmed) {
                    btnElement.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">refresh</span> <span>Đang lưu...</span>';
                    btnElement.disabled = true;
                    
                    fetch('/quan-tri/toggle-status/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ note: result.value || "" })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success === true || data.Success === true) {
                            // Thay button bằng span tĩnh (không click được)
                            var span = document.createElement('span');
                            span.className = "inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-700 border border-emerald-200 cursor-default";
                            span.title = "Đã xác nhận liên hệ";
                            span.innerHTML = '<span class="material-symbols-outlined text-sm">check_circle</span> <span>Đã liên hệ</span>';
                            btnElement.parentNode.replaceChild(span, btnElement);

                            // Cập nhật cột ghi chú
                            var noteData = data.newNote !== undefined ? data.newNote : data.NewNote;
                            if(noteData) {
                                var nc = document.getElementById('note-col-' + id);
                                if(nc) {
                                    nc.innerHTML = '<span class="italic">' + noteData + '</span>';
                                    nc.setAttribute('data-note', noteData);
                                }
                            }

                            Swal.mixin({
                                toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, 
                                timerProgressBar: true
                            }).fire({ icon: 'success', title: 'Cập nhật trạng thái thành công!' });
                        } else {
                            btnElement.innerHTML = '<span class="material-symbols-outlined text-sm">pending_actions</span> <span class="status-text">Chưa LH</span>';
                            btnElement.disabled = false;
                            var msg = data.message || data.Message || 'Không thể cập nhật trạng thái!';
                            Swal.fire({ icon: 'error', title: 'Lỗi', text: msg });
                        }
                    })
                    .catch(err => {
                        btnElement.innerHTML = '<span class="material-symbols-outlined text-sm">pending_actions</span> <span class="status-text">Chưa LH</span>';
                        btnElement.disabled = false;
                        Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Vui lòng kiểm tra lại mạng.' });
                    });
                }
            });
        }

        function editNote(id) {
            var col = document.getElementById('note-col-' + id);
            var currentNote = col.getAttribute('data-note') || '';
            
            Swal.fire({
                title: 'Sửa ghi chú',
                input: 'textarea',
                inputLabel: 'Nội dung ghi chú',
                inputValue: currentNote,
                showCancelButton: true,
                confirmButtonText: 'Lưu',
                cancelButtonText: 'Hủy',
                confirmButtonColor: '#3b82f6',
                heightAuto: false,
                scrollbarPadding: false
            }).then((result) => {
                if (result.isConfirmed) {
                    var newNote = result.value || "";
                    
                    fetch('/quan-tri/update-note/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ note: newNote })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success === true || data.Success === true) {
                            var updatedNote = data.newNote !== undefined ? data.newNote : data.NewNote;
                            col.setAttribute('data-note', updatedNote || '');
                            if(updatedNote) {
                                col.innerHTML = '<span class="italic">' + updatedNote + '</span>';
                            } else {
                                col.innerHTML = '<span class="text-slate-300">--</span>';
                            }

                            Swal.mixin({
                                toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, 
                                timerProgressBar: true
                            }).fire({ icon: 'success', title: 'Cập nhật ghi chú thành công!' });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message || data.Message || 'Không thể cập nhật ghi chú!' });
                        }
                    })
                    .catch(err => {
                        Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Vui lòng kiểm tra lại mạng.' });
                    });
                }
            });
        }

        function deleteContact(id, btnElement) {
            Swal.fire({
                title: 'Bạn có chắc chắn muốn xóa?',
                text: "Hành động này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy',
                heightAuto: false,
                scrollbarPadding: false
            }).then((result) => {
                if (result.isConfirmed) {
                    btnElement.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">refresh</span>';
                    btnElement.disabled = true;

                    fetch('/quan-tri/delete-registration/' + id, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success === true || data.Success === true) {
                            var tr = btnElement.closest('tr');
                            tr.style.opacity = '0';
                            setTimeout(() => {
                                tr.remove();
                            }, 300);
                            Swal.mixin({
                                toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, 
                                timerProgressBar: true
                            }).fire({ icon: 'success', title: 'Xóa thành công!' });
                        } else {
                            btnElement.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
                            btnElement.disabled = false;
                            Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message || data.Message || 'Không thể xóa bản ghi!' });
                        }
                    })
                    .catch(err => {
                        btnElement.innerHTML = '<span class="material-symbols-outlined text-[18px]">delete</span>';
                        btnElement.disabled = false;
                        Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Vui lòng kiểm tra lại mạng.' });
                    });
                }
            });
        }
    </script>
    <script>
        function toggleSidebar() {
            document.body.classList.toggle('sidebar-open');
        }
    </script>
</body>
</html>
