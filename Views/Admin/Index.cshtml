@model IEnumerable<Fucam.Models.Registration>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị Fucamp Lê Lợi</title>
    <link rel="icon" href="/img/logo.png" type="image/png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 h-full flex flex-col text-white">
        <div class="p-6 pb-2 border-b border-slate-800 flex flex-col">
            <div class="text-2xl font-black text-amber-500 tracking-wide flex items-center gap-3">
                <img src="/img/logo.png" alt="Fucamp Lê Lợi" class="h-9 object-contain brightness-0 invert drop-shadow-[0_2px_4px_rgba(0,0,0,0.4)]" />
                FUCAMP
            </div>
            <div class="text-[11px] text-slate-400 font-bold tracking-widest mt-2 uppercase ml-12">Quản trị hệ thống</div>
        </div>
        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/quan-tri" class="flex items-center gap-3 py-3 px-4 rounded-xl transition bg-blue-600 text-white font-medium shadow-md shadow-blue-900/20">
                <span class="material-symbols-outlined">dataset</span>
                Danh sách đăng ký
            </a>
        </nav>
        <div class="p-4 border-t border-slate-800">
             <a href="/quan-tri/logout" class="flex items-center gap-3 py-3 px-4 rounded-xl transition text-red-400 hover:bg-slate-800 hover:text-red-300 font-medium w-full">
                <span class="material-symbols-outlined">logout</span>
                Đăng xuất
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-full overflow-hidden">
        <!-- Header -->
        <header class="bg-white border-b border-slate-200 px-8 py-4 flex justify-between items-center shrink-0">
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Danh sách đăng ký</h1>
            <div class="flex items-center gap-3">
                <div class="text-right hidden md:block">
                    <div class="text-sm font-semibold text-slate-700">Admin</div>
                    <div class="text-xs text-slate-500">Quản trị viên</div>
                </div>
                <div class="w-10 h-10 rounded-full bg-slate-200 border-2 border-white shadow-sm flex items-center justify-center text-slate-500">
                    <span class="material-symbols-outlined">person</span>
                </div>
            </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-auto p-8 bg-slate-50">
            <!-- Analytics Cards & Chart -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <!-- Data Cards -->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-medium text-slate-500 mb-1">Tổng đăng ký</p>
                            <h3 class="text-3xl font-black text-slate-800">@ViewBag.GlobalTotal</h3>
                        </div>
                        <div class="w-14 h-14 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl">groups</span>
                        </div>
                    </div>
                    <div class="bg-gradient-to-br from-amber-500 to-orange-500 p-6 rounded-2xl shadow-md border border-amber-400 flex items-center justify-between text-white">
                        <div>
                            <p class="text-sm font-medium text-orange-100 mb-1">Đăng ký hôm nay</p>
                            <h3 class="text-3xl font-black">@ViewBag.TodayTotal</h3>
                        </div>
                        <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center">
                            <span class="material-symbols-outlined text-3xl">today</span>
                        </div>
                    </div>
                </div>

                <!-- Chart Canvas -->
                <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                    <h3 class="text-base font-bold text-slate-800 mb-4">Lưu lượng đăng ký (7 ngày qua)</h3>
                    <div class="h-48 w-full relative">
                        <canvas id="registrationChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Filter Actions -->
            <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6">
                <!-- Search -->
                <form method="get" class="w-full md:w-96 relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Tìm tên p.huynh, SĐT, Tên bé..." class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-sm shadow-sm" />
                    @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                    {
                        <a href="/quan-tri" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-red-500" title="Xóa bộ lọc">
                           <span class="material-symbols-outlined text-sm">close</span>
                        </a>
                    }
                </form>
                
                <div class="text-sm text-slate-600 bg-white px-4 py-2 rounded-xl border border-slate-200 shadow-sm font-medium">
                    Tổng cộng: <span class="text-blue-600 font-bold">@ViewBag.TotalRecords</span> bản ghi
                </div>
            </div>

            <!-- Table -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200 text-slate-600 text-sm">
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Thời gian</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Họ tên Phụ huynh</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Số điện thoại</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap">Email</th>
                                <th class="py-4 px-6 font-semibold min-w-[200px]">Họ tên & Tuổi của con</th>
                                <th class="py-4 px-6 font-semibold min-w-[150px]">Ghi chú</th>
                                <th class="py-4 px-6 font-semibold whitespace-nowrap text-center">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr class="border-b border-slate-100 hover:bg-slate-50/80 transition-colors">
                                        <td class="py-4 px-6 text-slate-500">
                                            <div class="font-medium text-slate-700">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                                            <div class="text-xs">@item.CreatedAt.ToString("HH:mm")</div>
                                        </td>
                                        <td class="py-4 px-6 font-medium text-slate-800">
                                            @item.ParentName
                                        </td>
                                        <td class="py-4 px-6 font-medium text-blue-600">
                                            @item.PhoneNumber
                                        </td>
                                        <td class="py-4 px-6 text-slate-600">
                                            @if(!string.IsNullOrEmpty(item.Email))
                                            {
                                                <a href="mailto:@item.Email" class="hover:text-blue-600 hover:underline">@item.Email</a>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 italic">--</span>
                                            }
                                        </td>
                                        <td class="py-4 px-6">
                                            <div class="bg-orange-50 text-orange-800 px-3 py-1.5 rounded-lg border border-orange-100 inline-block">
                                                @item.ChildInfo
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 text-slate-600 text-sm max-w-[200px] break-words" id="note-col-@item.Id">
                                            @if(!string.IsNullOrEmpty(item.Notes))
                                            {
                                                <span class="italic">@item.Notes</span>
                                            }
                                            else
                                            {
                                                <span class="text-slate-300">--</span>
                                            }
                                        </td>
                                        <td class="py-4 px-6 text-center">
                                            <button onclick="toggleStatus(@item.Id, this)" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold transition-all shadow-sm focus:ring-2 focus:ring-offset-1 @(item.Status == 1 ? "bg-emerald-100 text-emerald-700 border border-emerald-200 hover:bg-emerald-200 focus:ring-emerald-400" : "bg-rose-100 text-rose-700 border border-rose-200 hover:bg-rose-200 focus:ring-rose-400")">
                                                @if(item.Status == 1) {
                                                    <span class="material-symbols-outlined text-sm">check_circle</span> <span class="status-text">Đã liên hệ</span>
                                                } else {
                                                    <span class="material-symbols-outlined text-sm">pending_actions</span> <span class="status-text">Chưa LH</span>
                                                }
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="py-12 text-center text-slate-500 flex-col items-center">
                                        <span class="material-symbols-outlined text-4xl text-slate-300 mb-2 block">inbox</span>
                                        Không tìm thấy dữ liệu đăng ký nào.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                @if (ViewBag.TotalPages > 1)
                {
                    <div class="px-6 py-4 border-t border-slate-200 flex justify-between items-center bg-slate-50/50">
                        <div class="text-sm text-slate-500">
                            Trang <span class="font-medium text-slate-800">@ViewBag.CurrentPage</span> / @ViewBag.TotalPages
                        </div>
                        <div class="flex gap-1">
                            @if (ViewBag.CurrentPage > 1)
                            {
                                <a href="/quan-tri?page=@(ViewBag.CurrentPage - 1)&searchString=@ViewBag.SearchString" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition">
                                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                                </a>
                            }
                            
                            <!-- Hiển thị nhanh tối đa 5 trang -->
                            @{
                                int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                int endPage = Math.Min(ViewBag.TotalPages, startPage + 4);
                                if (endPage - startPage < 4) { startPage = Math.Max(1, endPage - 4); }
                            }
                            
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                if (i == ViewBag.CurrentPage)
                                {
                                    <span class="w-9 h-9 flex items-center justify-center rounded-lg bg-blue-600 text-white font-medium text-sm shadow-sm">@i</span>
                                }
                                else
                                {
                                    <a href="/quan-tri?page=@i&searchString=@ViewBag.SearchString" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 font-medium text-sm transition">@i</a>
                                }
                            }

                            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                            {
                                <a href="/quan-tri?page=@(ViewBag.CurrentPage + 1)&searchString=@ViewBag.SearchString" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 hover:text-blue-600 transition">
                                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </main>

    <script>
        const ctx = document.getElementById('registrationChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 200);
        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
        gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels)],
                datasets: [{
                    label: 'Số lượt đăng ký',
                    data: [@Html.Raw(ViewBag.ChartCounts)],
                    borderColor: '#2563eb',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#2563eb',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, precision: 0 },
                        grid: { borderDash: [2, 4], color: '#e2e8f0' }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
    <script>
        function toggleStatus(id, btnElement) {
            let orHTML = btnElement.innerHTML;
            let orClass = btnElement.className;
            let isCurrentlyContacted = orHTML.indexOf('check_circle') !== -1;

            if (!isCurrentlyContacted) {
                // Đang là Chưa liên hệ -> Đã liên hệ (Cần hỏi Notes)
                Swal.fire({
                    title: 'Đã liên hệ khách hàng?',
                    input: 'textarea',
                    inputLabel: 'Ghi chú thêm (Không bắt buộc)',
                    inputPlaceholder: 'Nhập nội dung trao đổi...',
                    showCancelButton: true,
                    confirmButtonText: 'Lưu trạng thái',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        doToggle(id, btnElement, orHTML, orClass, result.value || "");
                    }
                });
            } else {
                doToggle(id, btnElement, orHTML, orClass, "");
            }
        }

        function doToggle(id, btnElement, orHTML, orClass, noteContent) {
            btnElement.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">refresh</span> <span class="status-text">Đang lưu...</span>';
            
            fetch('/quan-tri/toggle-status/' + id, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ note: noteContent })
            })
            .then(res => res.json())
            .then(data => {
                let st = data.newStatus !== undefined ? data.newStatus : data.NewStatus;
                
                if(data.success === true || data.Success === true) {
                    if(st == 1) {
                        btnElement.className = "inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold transition-all shadow-sm focus:ring-2 focus:ring-offset-1 bg-emerald-100 text-emerald-700 border border-emerald-200 hover:bg-emerald-200 focus:ring-emerald-400";
                        btnElement.innerHTML = '<span class="material-symbols-outlined text-sm">check_circle</span> <span class="status-text">Đã liên hệ</span>';
                        let noteData = data.newNote !== undefined ? data.newNote : data.NewNote;
                        if(noteData) {
                            let nc = document.getElementById('note-col-' + id);
                            if(nc) nc.innerHTML = '<span class="italic">' + noteData + '</span>';
                        }
                    } else {
                        btnElement.className = "inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-bold transition-all shadow-sm focus:ring-2 focus:ring-offset-1 bg-rose-100 text-rose-700 border border-rose-200 hover:bg-rose-200 focus:ring-rose-400";
                        btnElement.innerHTML = '<span class="material-symbols-outlined text-sm">pending_actions</span> <span class="status-text">Chưa LH</span>';
                    }
                    Swal.mixin({
                        toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, 
                        timerProgressBar: true
                    }).fire({ icon: 'success', title: 'Cập nhật trạng thái thành công!' });
                } else {
                    btnElement.className = orClass;
                    btnElement.innerHTML = orHTML;
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Không thể cập nhật trạng thái!' });
                }
            })
            .catch(err => {
                btnElement.className = orClass;
                btnElement.innerHTML = orHTML;
                Swal.fire({ icon: 'error', title: 'Lỗi kết nối', text: 'Vui lòng kiểm tra lại mạng.' });
            });
        }
    </script>
</body>
</html>
