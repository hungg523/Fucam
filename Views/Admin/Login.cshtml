@model Fucam.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị Fucamp Lê Lợi</title>
    <link rel="icon" href="/img/logo.png" type="image/png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/img/ngay1.jpg')] bg-cover bg-center opacity-10"></div>
    <div class="bg-white p-8 rounded-2xl shadow-xl w-96 relative z-10 border-t-4 border-amber-500">
        <img src="/img/logo.png" alt="Fucamp Lê Lợi Logo" class="h-16 mx-auto mb-3 object-contain drop-shadow-sm" />
        <h2 class="text-2xl font-black text-center mb-6 text-gray-800 tracking-tight">HỆ THỐNG QUẢN TRỊ</h2>
        <form asp-action="Login" method="post">
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Tài khoản</label>
                <input asp-for="Username" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="admin" autofocus />
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Mật khẩu</label>
                <input asp-for="Password" type="password" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" placeholder="******" />
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-blue-700 transition">Đăng Nhập</button>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Đăng nhập thất bại!',
                text: '@Html.Raw(TempData["Error"])',
                confirmButtonText: 'Thử lại',
                confirmButtonColor: '#dc2626'
            });
        </script>
    }
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Thành công!',
                text: '@Html.Raw(TempData["Success"])',
                confirmButtonText: 'Đóng',
                confirmButtonColor: '#16a34a'
            });
        </script>
    }
</body>
</html>
